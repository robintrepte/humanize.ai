# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DOMAIN="localhost:3003"
# Production: set to your public origin, e.g. https://humanize.example.com
NEXTAUTH_URL="http://localhost:3003"

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/humanizeai"

# -----------------------------------------------------------------------------
# Auth (Auth.js v5)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
# Set AUTH_TRUST_HOST=true in production when behind a reverse proxy (e.g. Vercel).
# After changing AUTH_SECRET or upgrading from NextAuth v4, clear this site's cookies to fix JWTSessionError.
# AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# OAuth — Google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# Email — Auth (magic links)
# -----------------------------------------------------------------------------
EMAIL="your-email@example.com"
EMAIL_PASSWORD="your-email-password"
# Optional: EMAIL_SERVER_HOST (default: send.one.com), EMAIL_SERVER_PORT (default: 465)

# -----------------------------------------------------------------------------
# Email — Support form
# -----------------------------------------------------------------------------
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
# Optional: SMTP_HOST, SMTP_PORT, SMTP_SECURE, SUPPORT_EMAIL

# -----------------------------------------------------------------------------
# Payments — Mollie
# -----------------------------------------------------------------------------
MOLLIE_API_KEY="your-mollie-api-key"
# Required in production when MOLLIE_API_KEY is set. Mollie Dashboard → Webhooks → signing secret.
MOLLIE_WEBHOOK_SECRET="your-webhook-signing-secret"

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------
AI_PROVIDER="openai"
AI_MODEL="gpt-5-nano"
ANTHROPIC_API_KEY="your-anthropic-api-key"
OPENAI_API_KEY="your-openai-api-key"
ZEROGPT_API_KEY="your-zerogpt-api-key"
